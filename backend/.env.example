PORT=8000
NODE_ENV=production

MONGO_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>"

JWT_SECRET=<generate-a-64-byte-hex-secret>
JWT_EXPIRES_IN=7d

SESSION_SECRET=<generate-a-64-byte-hex-secret>
SESSION_EXPIRES_IN=1d

GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_CALLBACK_URL=https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_URI=https://<your-domain>/auth/callback

FRONTEND_ORIGIN=https://<your-domain>
FRONTEND_GOOGLE_CALLBACK_URL=https://<your-domain>/auth/callback
